// EduSpawn — PostgreSQL on AWS RDS only (TLS via DATABASE_URL, e.g. ?sslmode=require)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Add models as features land; run migrations against RDS (or a CI mirror of the same engine).
