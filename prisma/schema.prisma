// EduSpawn — PostgreSQL on AWS RDS only (TLS via DATABASE_URL, e.g. ?sslmode=require)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

