# Copy this file to .env and fill in real values.
# Never commit your real .env file to Git.
# Prefer storing secrets in AWS Secrets Manager / Parameter Store.

# --------------------------------------------------
# App
# --------------------------------------------------
# Use "development" locally, "production" on EC2/server.
NODE_ENV=development
PORT=3000

APP_NAME=EduSpawn

# Until billing/subscriptions are implemented:
# allowed values: free | pro | premium
DEFAULT_PLAN_TIER=free

# Optional: comma-separated browser origins.
# Leave empty in local development if your app allows open CORS there.
# Example:
# CORS_ORIGIN=http://localhost:8081,https://app.eduspawn.com
CORS_ORIGIN=

# --------------------------------------------------
# Database (AWS RDS PostgreSQL)
# --------------------------------------------------
# TLS required for AWS RDS.
# Example:
# DATABASE_URL=postgresql://USER:PASSWORD@your-db.xxxxxx.region.rds.amazonaws.com:5432/eduspawn?sslmode=require
DATABASE_URL=

# Optional split DB fields (only keep if your app/config uses them)
# DB_HOST=
# DB_PORT=5432
# DB_NAME=eduspawn
# DB_USER=
# DB_PASSWORD=
# DB_SSL=true

# --------------------------------------------------
# Auth / JWT
# --------------------------------------------------
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=7d

# --------------------------------------------------
# AI Provider API Keys
# Leave blank here; fill in only in real .env
# --------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --------------------------------------------------
# Provider-level model routing
# These are the main model variables used by the upgraded router.
# --------------------------------------------------

# OpenAI
OPENAI_MODEL_FAST=gpt-5-mini
OPENAI_MODEL_SMART=gpt-5

# Anthropic
ANTHROPIC_MODEL_FAST=claude-haiku-4-5
ANTHROPIC_MODEL_BALANCED=claude-sonnet-4-6
ANTHROPIC_MODEL_PREMIUM=claude-opus-4-6

# Gemini
GEMINI_MODEL_FAST=gemini-2.5-flash
GEMINI_MODEL_SMART=gemini-2.5-pro

# --------------------------------------------------
# Legacy single-model fallback variables
# Optional. Only use if you want one model per provider.
# The router supports them as fallback, but provider-level FAST/SMART/BALANCED/PREMIUM
# variables above are the preferred structure.
# --------------------------------------------------
# OPENAI_MODEL=
# ANTHROPIC_MODEL=
# GEMINI_MODEL=

# --------------------------------------------------
# Optional task-specific model overrides
# Use these only if you want to override routing for a specific task/tier.
# If left blank or omitted, router falls back to provider-level model variables above.
# --------------------------------------------------

# lesson_generation
# LESSON_FREE_MODEL=
# LESSON_PRO_MODEL=
# LESSON_PREMIUM_MODEL=

# short_video_script
# SHORT_VIDEO_FREE_MODEL=
# SHORT_VIDEO_PRO_MODEL=
# SHORT_VIDEO_PREMIUM_MODEL=

# long_video_script
# LONG_VIDEO_FREE_MODEL=
# LONG_VIDEO_PRO_MODEL=
# LONG_VIDEO_PREMIUM_MODEL=

# critic_review
# CRITIC_FREE_MODEL=
# CRITIC_PRO_MODEL=
# CRITIC_PREMIUM_MODEL=

# quiz_generation
# QUIZ_FREE_MODEL=
# QUIZ_PRO_MODEL=
# QUIZ_PREMIUM_MODEL=

# carousel_post
# CAROUSEL_FREE_MODEL=
# CAROUSEL_PRO_MODEL=
# CAROUSEL_PREMIUM_MODEL=

# narration
# NARRATION_FREE_MODEL=
# NARRATION_PRO_MODEL=
# NARRATION_PREMIUM_MODEL=

# image_prompt
# IMAGE_PROMPT_FREE_MODEL=
# IMAGE_PROMPT_PRO_MODEL=
# IMAGE_PROMPT_PREMIUM_MODEL=

# --------------------------------------------------
# Render pipeline (creator pack → video job; render credits)
# --------------------------------------------------
# RENDER_CREATOR_PACK_SHORT_CREDIT_COST=1
# RENDER_CREATOR_PACK_LONG_CREDIT_COST=2
# RENDER_DEFAULT_PROVIDER=KLING_STUB
# RENDER_KLING_STUB_MODE=submit_fail
# RENDER_KLING_STUB_MODE=submit_ok
# RENDER_WEBHOOK_SECRET=replace_with_long_random_shared_secret
# RENDER_KLING_API_KEY=
# RENDER_KLING_API_BASE_URL=https://api.klingapi.com
# RENDER_KLING_MODEL=kling-v2.6-pro
# RENDER_KLING_CALLBACK_URL=https://your-app.example.com/api/v1/render/webhooks/provider
# RENDER_KLING_DEFAULT_ASPECT_RATIO=16:9
# RENDER_KLING_DEFAULT_MODE=professional
# RENDER_KLING_NEGATIVE_PROMPT=
# RENDER_WEBHOOK_MAX_CLOCK_SKEW_SEC=600