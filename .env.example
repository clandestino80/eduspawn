# Copy to .env and fill with values from AWS Secrets Manager / Parameter Store — never commit .env

NODE_ENV=development
PORT=3000

# AWS RDS PostgreSQL — TLS required (sslmode in URL)
# Example: postgresql://USER:PASSWORD@your-db.xxxxxx.region.rds.amazonaws.com:5432/eduspawn?sslmode=require
DATABASE_URL=

# Optional: comma-separated browser origins (omit in dev to allow any origin)
# CORS_ORIGIN=https://app.eduspawn.example
